# CyreneBot environment example.
#
# start.py loads a project .env file for local startup and does not override
# existing shell variables. The server module itself does not auto-load .env
# files; in production, inject these through systemd EnvironmentFile,
# Docker/Compose env_file, shell export, or your deployment platform.

# Runtime config path. Equivalent to: python start.py --config /etc/cyrene/config.yaml
CYRENEAI_CONFIG=/etc/cyrene/config.yaml

# Console auth. If username or password is missing while auth is enabled, the
# web console is not mounted and admin APIs report that auth is not configured.
CYRENEAI_AUTH_ENABLED=true
CYRENEAI_ADMIN_USERNAME=admin
CYRENEAI_ADMIN_PASSWORD=change-me
CYRENEAI_SESSION_SECRET=change-me-to-a-long-random-secret
CYRENEAI_SESSION_COOKIE_NAME=cyrene_admin_session
CYRENEAI_SESSION_TTL_SECONDS=43200

# Provider secrets referenced by config.yaml.
OPENAI_RESPONSES_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# Optional legacy provider environment configuration. These still work and
# override same-id providers loaded from CYRENEAI_CONFIG.
OPENAI_RESPONSES_PROVIDER_ID=openai
OPENAI_RESPONSES_BASE_URL=
OPENAI_RESPONSES_MODEL=
OPENAI_RESPONSES_MODELS=
OPENAI_COMPATIBLE_PROVIDER_ID=openai-compatible
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_MODELS=
ANTHROPIC_PROVIDER_ID=anthropic
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_MODELS=
GOOGLE_GENAI_PROVIDER_ID=google
GOOGLE_GENAI_BASE_URL=
GOOGLE_GENAI_MODEL=
GOOGLE_GENAI_MODELS=
CYRENE_PROVIDER_TIMEOUT_SECONDS=60

# Storage paths.
CYRENEAI_PROVIDER_CONFIG_STORE_PATH=data/providers.json
CYRENEAI_CONTEXT_DATABASE_PATH=data/context.db
CYRENEAI_VECTOR_DATABASE_PATH=data/vector.db
CYRENEAI_BOT_POLLING_STATE_DATABASE_PATH=data/bot_polling_state.db

# Logging.
CYRENEAI_LOG_LEVEL=INFO
CYRENEAI_LOG_FORMAT=text
CYRENEAI_LOG_REQUESTS_ENABLED=true
CYRENEAI_REQUEST_ID_HEADER=X-Request-ID

# Telegram integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
TELEGRAM_BOT_PROVIDER_ID=
TELEGRAM_BOT_MODEL=
TELEGRAM_BOT_MODE=

# QQ integration.
QQ_BOT_ACCESS_TOKEN=
QQ_BOT_APP_ID=
QQ_BOT_APP_SECRET=
QQ_BOT_BASE_URL=https://api.sgroup.qq.com
QQ_BOT_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
QQ_BOT_WEBHOOK_SECRET=
QQ_BOT_PROVIDER_ID=
QQ_BOT_MODEL=
QQ_BOT_MODE=

# Optional tools/plugins.
CYRENEAI_CONTROLLED_SHELL_ENABLED=false
CYRENEAI_PLUGIN_PATH=
CYRENEAI_DISABLED_PLUGINS=
